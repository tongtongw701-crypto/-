# ============================================================
# 法律智能问答系统 - 环境变量配置模板
# 复制本文件为 .env 并填入您的实际配置
# cp .env.example .env
# ============================================================

# [必须] LLM API Key (根据所选厂商填写)
LLM_API_KEY=your_api_key_here

# [必须] LLM 厂商 (可选值: dashscope / deepseek / xiaomi / moonshot / zhipu / openai)
LLM_PROVIDER=dashscope

# [可选] 模型名称 (留空则使用厂商默认值)
# 厂商默认: dashscope=qwen-max, deepseek=deepseek-chat, xiaomi=MiLM-6B 等
# LLM_MODEL=qwen-max

# [可选] API Base URL (留空则使用厂商默认值，一般无需修改)
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# [可选] 嵌入模型
# EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# [可选] Chroma Server 配置 (如果使用远程 Chroma Server 代替本地向量库)
# CHROMA_SERVER_URL=http://localhost:8000

# [可选] 检索参数调优
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# TOP_K_RESULTS=4
# SIMILARITY_THRESHOLD=0.4

# [可选] 评估相关
# EVAL_RETRIEVER=chroma_server
# EVAL_SET=eval/eval_set.jsonl
# EVAL_LIMIT=0
