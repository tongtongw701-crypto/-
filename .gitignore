# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/

# --- 虚拟环境 ---
.venv/
venv/
ENV/
env/

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~
*.iml

# --- 环境变量 (包含 API Key) ---
.env

# --- 向量数据库 (体积大，需用户自行初始化) ---
vector_db/
eval_cache/

# --- 模型文件 (体积大，需用户自行下载) ---
models/

# --- 日志 ---
logs/
*.log

# --- 评估结果 (运行时生成) ---
rag_eval_results.csv
*.csv

# --- 操作系统 ---
.DS_Store
Thumbs.db
desktop.ini

# --- PyInstaller 打包产物 ---
dist/
build/
*.spec.bak
__pycache__/

# --- 便携版构建产物 ---
portable/
output/

# --- 文档构建产物 ---
docs/_build/
